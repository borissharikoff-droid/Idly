{
  "name": "grindly",
  "version": "4.3.0",
  "description": "Windows productivity tracker with session timer, activity monitoring, and gamification",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5174 && electron . --remote-debugging-port=9222\"",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "clean:release": "node -e \"try{require('fs').rmSync('release/win-unpacked',{recursive:true,force:true});console.log('Cleaned release/win-unpacked')}catch(e){console.warn('Clean skipped:',e.message)}\"",
    "electron:build": "npm run build && npm run clean:release && electron-builder --config electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest",
    "push": "git push",
    "qa": "node scripts/qa-full-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-virtual": "^3.13.19",
    "better-sqlite3": "^11.5.0",
    "discord-rpc": "^4.0.1",
    "dotenv": "^16.6.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.577.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.grindly.app",
    "productName": "Grindly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
